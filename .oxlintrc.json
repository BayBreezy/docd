{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/.nuxt",
    "**/.output",
    "**/.data",
    "**/.cache",
    "**/coverage",
    "**/dist",
    "**/.vite",
    ".starters/default/**",
    "docs-llms/**"
  ],
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "typescript/no-floating-promises": "error"
  }
}
